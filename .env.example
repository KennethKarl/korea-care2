# KoreCare — 환경변수 예시
# 실제 값은 .env.local (로컬) 또는 GitHub Actions repo secrets 로 주입.
# 미설정 시: 분석/ChannelTalk = 비활성(no-op), 폼 = mock 성공(정적에서도 무에러).

# 세이프닥 백엔드 base URL (폼 제출). 예: https://api.safedoc.io
VITE_API_BASE=

# GA4 측정 ID (예: G-XXXXXXXXXX)
VITE_GA4_ID=

# Meta(Facebook) Pixel ID
VITE_META_PIXEL_ID=

# Microsoft Clarity 프로젝트 ID
VITE_CLARITY_ID=

# ChannelTalk plugin key
VITE_CHANNEL_PLUGIN_KEY=
